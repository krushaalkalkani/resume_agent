%# resume.tex.j2 — rendered by src/render.py with custom Jinja delimiters.
%#   \VAR{ x | tex }       -> escaped value
%#   \BLOCK{ if x }..\BLOCK{ endif } -> INLINE conditional (mid-line)
%#   %% for / %% if        -> block on its OWN line only
\documentclass[letterpaper,11pt]{article}

\usepackage{latexsym}
\usepackage[empty]{fullpage}
\usepackage{titlesec}
\usepackage[usenames,dvipsnames]{color}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{fancyhdr}
\usepackage[english]{babel}
\usepackage{tabularx}

\pagestyle{fancy}
\fancyhf{}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

\addtolength{\oddsidemargin}{-0.6in}
\addtolength{\evensidemargin}{-0.6in}
\addtolength{\textwidth}{1.19in}
\addtolength{\topmargin}{-.7in}
\addtolength{\textheight}{1.4in}

\urlstyle{same}
\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}

\titleformat{\section}{\vspace{-4pt}\scshape\raggedright\large}{}{0em}{}[\color{black}\titlerule \vspace{-5pt}]

\newcommand{\resumeItem}[1]{\item\small{{#1 \vspace{-2pt}}}}
\newcommand{\resumeSubheading}[4]{%
  \vspace{-2pt}\item
    \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & #2 \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-7pt}%
}
\newcommand{\resumeProjectHeading}[2]{%
  \item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \small#1 & #2 \\
    \end{tabular*}\vspace{-7pt}%
}
\renewcommand\labelitemii{$\vcenter{\hbox{\tiny$\bullet$}}$}
\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=0.15in, label={}]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-5pt}}

\begin{document}

%---------- HEADING ----------
\begin{center}
    {\Huge \scshape \VAR{ full_name | tex }} \\ \vspace{3pt}
    \small \VAR{ contact_line }
\end{center}

%% if profile.summary
\section{Summary}
\small{\VAR{ profile.summary | tex }}
\vspace{-4pt}
%% endif

%---------- EDUCATION ----------
%% if education
\section{Education}
  \resumeSubHeadingListStart
%% for e in education
    \resumeSubheading
      {\VAR{ e.school | tex }}{\VAR{ e.location | tex }}
      {\VAR{ e.degree | tex }\BLOCK{ if e.major }, \VAR{ e.major | tex }\BLOCK{ endif }\BLOCK{ if e.gpa } \quad GPA: \VAR{ '%.2f'|format(e.gpa) }/4.0\BLOCK{ endif }}{\VAR{ e.date | tex }}
%% endfor
  \resumeSubHeadingListEnd
%% endif

%---------- EXPERIENCE ----------
%% if experience
\section{Experience}
  \resumeSubHeadingListStart
%% for x in experience
    \resumeSubheading
      {\VAR{ x.role | tex }}{\VAR{ x.date | tex }}
      {\VAR{ x.company | tex }}{\VAR{ x.location | tex }}
%% if x.bullets
      \resumeItemListStart
%% for b in x.bullets
        \resumeItem{\VAR{ b | tex }}
%% endfor
      \resumeItemListEnd
%% endif
%% endfor
  \resumeSubHeadingListEnd
%% endif

%---------- PROJECTS ----------
%% if projects
\section{Projects}
    \resumeSubHeadingListStart
%% for p in projects
      \resumeProjectHeading
        {\textbf{\VAR{ p.name | tex }}\BLOCK{ if p.tech_stack } $|$ \emph{\VAR{ p.tech_stack | tex }}\BLOCK{ endif }}{\BLOCK{ if p.github }\href{\VAR{ p.github | ensure_scheme | href }}{\underline{Code}}\BLOCK{ endif }\BLOCK{ if p.github and p.demo } $|$ \BLOCK{ endif }\BLOCK{ if p.demo }\href{\VAR{ p.demo | ensure_scheme | href }}{\underline{Demo}}\BLOCK{ endif }\BLOCK{ if p.date } \quad \VAR{ p.date | tex }\BLOCK{ endif }}
%% if p.bullets
          \resumeItemListStart
%% for b in p.bullets
            \resumeItem{\VAR{ b | tex }}
%% endfor
          \resumeItemListEnd
%% endif
%% endfor
    \resumeSubHeadingListEnd
%% endif

%---------- TECHNICAL SKILLS ----------
%% if skills
\section{Technical Skills}
 \begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{
%% for s in skills
     \textbf{\VAR{ s.category | tex }}: \VAR{ s.skills | join(', ') | tex } \\
%% endfor
    }}
 \end{itemize}
 \vspace{-12pt}
%% endif

%---------- CERTIFICATIONS ----------
%% if certifications
\section{Certifications}
 \begin{itemize}[leftmargin=0.15in, label={}]
    \small{\item{
%% for c in certifications
     \textbf{\VAR{ c.name | tex }}\BLOCK{ if c.provider } --- \emph{\VAR{ c.provider | tex }}\BLOCK{ endif } \\
%% endfor
    }}
 \end{itemize}
 \vspace{-12pt}
%% endif

%---------- LEADERSHIP ----------
%% if leadership
\section{Leadership \& Involvement}
  \resumeSubHeadingListStart
%% for l in leadership
    \resumeSubheading
      {\VAR{ l.title | tex }}{\VAR{ l.date | tex }}
      {\VAR{ l.organization | tex }}{\VAR{ l.location | tex }}
%% endfor
  \resumeSubHeadingListEnd
%% endif

\end{document}
